@{
    ViewData["Title"] = "Leave Feedback";
    var bookTitle = ViewData["BookTitle"] as string;
    var bookId = ViewData["BookId"];
}

<h1>Leave Feedback</h1>
<h4 class="text-muted">for: <strong>@bookTitle</strong></h4>

<div class="form-container">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="bookId" value="@bookId" />

        <div class="mb-3">
            <label class="form-label fw-bold">Rating</label>
            <div class="d-flex gap-2">
                @for (int i = 1; i <= 5; i++)
                {
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="rating" value="@i" id="star@i" required />
                        <label class="form-check-label" for="star@i">@i ★</label>
                    </div>
                }
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Comment</label>
            <textarea name="comment" class="form-control" rows="4"
                      placeholder="Share your thoughts about this book..." required maxlength="500"></textarea>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Submit Feedback</button>
            <a asp-action="MyFeedback" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>