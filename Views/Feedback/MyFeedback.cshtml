@model IEnumerable<LibraryManagemenytSystem.Models.Feedback>

@{
    ViewData["Title"] = "My Feedback";
}

<h1>My Feedback</h1>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        You have not submitted any feedback yet.
        <a asp-controller="Books" asp-action="Browse">Browse books</a> to leave a review!
    </div>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Book</th>
                <th>Rating</th>
                <th>Comment</th>
                <th>Date Submitted</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Book?.Title</strong></td>
                    <td>
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span style="color:@(i <= item.Rating ? "#f5a623" : "#ddd")">★</span>
                        }
                        (@item.Rating/5)
                    </td>
                    <td>@item.Comment</td>
                    <td>@item.DateSubmitted.ToString("dd/MM/yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
}