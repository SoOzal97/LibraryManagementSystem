@model IEnumerable<LibraryManagemenytSystem.Models.Feedback>

@{
    ViewData["Title"] = "Book Reviews";
    var bookTitle = ViewData["BookTitle"] as string;
    var bookId = ViewData["BookId"];
    var avgRating = ViewData["AverageRating"] as string;
}

<h1>Reviews for: @bookTitle</h1>

<div class="mb-3">
    <span class="fw-bold">Average Rating: </span>
    <span style="color:#f5a623; font-size:1.2rem;">★</span>
    <strong>@avgRating</strong>
</div>

@if (User.Identity != null && User.Identity.IsAuthenticated && !User.IsInRole("Librarian"))
{
    <a asp-action="Create" asp-route-bookId="@bookId" class="create-link mb-3">+ Leave a Review</a>
}

@if (!Model.Any())
{
    <div class="alert alert-info mt-3">No reviews yet. Be the first to review this book!</div>
}
else
{
    <div class="mt-3">
        @foreach (var item in Model)
        {
            <div class="feedback-card">
                <div class="feedback-header">
                    <strong>@item.User?.FullName</strong>
                    <span class="text-muted" style="font-size:0.85rem;">@item.DateSubmitted.ToString("dd/MM/yyyy")</span>
                </div>
                <div class="feedback-rating">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <span style="color:@(i <= item.Rating ? "#f5a623" : "#ddd")">★</span>
                    }
                </div>
                <p class="feedback-comment">@item.Comment</p>
            </div>
        }
    </div>
}

<a asp-controller="Books" asp-action="Details" asp-route-id="@bookId" class="btn btn-secondary mt-3">Back to Book</a>