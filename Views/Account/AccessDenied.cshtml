@{
    ViewData["Title"] = "Access Denied";
}

<div class="auth-container">
    <div class="auth-box text-center">
        <div class="auth-header">
            <h1>🚫 Access Denied</h1>
            <p>You do not have permission to view this page.</p>
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Go to Homepage</a>
        <a asp-controller="Account" asp-action="Login" class="btn btn-secondary mt-2">Login with different account</a>
    </div>
</div>
