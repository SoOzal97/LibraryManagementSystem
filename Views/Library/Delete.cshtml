@model LibraryManagemenytSystem.Models.Library

@{
    ViewData["Title"] = "Delete Library";
}

<h1>Delete Library</h1>

<div class="delete-container">
    <h4 class="text-danger">Are you sure you want to delete this library?</h4>

    <dl class="row mt-3">
        <dt class="col-sm-3">Library Name</dt>
        <dd class="col-sm-9">@Model.Name</dd>

        <dt class="col-sm-3">Location</dt>
        <dd class="col-sm-9">@Model.Location</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="LibraryId" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>