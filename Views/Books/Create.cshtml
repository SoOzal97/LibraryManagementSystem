@model LibraryManagemenytSystem.Models.Book

@{
    ViewData["Title"] = "Add New Book";
}

<h1>Add New Book</h1>

<div class="form-container">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Title" class="form-label"></label>
            <input asp-for="Title" class="form-control" placeholder="Enter book title" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Author" class="form-label"></label>
            <input asp-for="Author" class="form-control" placeholder="Enter author name" />
            <span asp-validation-for="Author" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Genre" class="form-label"></label>
            <input asp-for="Genre" class="form-control" placeholder="e.g. Fiction, Fantasy, Thriller" />
            <span asp-validation-for="Genre" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ISBN" class="form-label"></label>
            <input asp-for="ISBN" class="form-control" placeholder="Format: 978-XXXXXXXXXX" />
            <span asp-validation-for="ISBN" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter book description"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Cover Image</label>
            <input type="file" name="coverImage" class="form-control" accept="image/*" />
        </div>

        <div class="mb-3 form-check">
            <input asp-for="IsAvailable" class="form-check-input" />
            <label asp-for="IsAvailable" class="form-check-label">Available</label>
        </div>

        <div class="mb-3">
            <label asp-for="DateAdded" class="form-label"></label>
            <input asp-for="DateAdded" class="form-control" type="date" />
            <span asp-validation-for="DateAdded" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="TotalCopies" class="form-label"></label>
            <input asp-for="TotalCopies" class="form-control" type="number" min="0" max="10" />
            <span asp-validation-for="TotalCopies" class="text-danger"></span>
            <small class="text-muted">Maximum 10 copies per book</small>
        </div>

        <input type="hidden" asp-for="AvailableCopies" />

        <div class="d-flex gap-2">
            <input type="submit" value="Create Book" class="btn btn-primary" />
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}