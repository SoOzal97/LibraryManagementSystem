@model IEnumerable<LibraryManagemenytSystem.Models.Book>

@{
    ViewData["Title"] = "Books";
}

<h1>Book Management</h1>

@if (User.IsInRole("Librarian"))
{
    <a asp-action="Create" class="create-link">+ Create New Book</a>
}

<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Title)</th>
            <th>@Html.DisplayNameFor(model => model.Author)</th>
            <th>@Html.DisplayNameFor(model => model.Genre)</th>
            <th>@Html.DisplayNameFor(model => model.ISBN)</th>
            <th>Total Copies</th>
            <th>Available Copies</th>
            <th>Status</th>
            <th>@Html.DisplayNameFor(model => model.Description)</th>
            <th>@Html.DisplayNameFor(model => model.DateAdded)</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Title)</td>
                <td>@Html.DisplayFor(modelItem => item.Author)</td>
                <td>@Html.DisplayFor(modelItem => item.Genre)</td>
                <td>@Html.DisplayFor(modelItem => item.ISBN)</td>
                <td>@item.TotalCopies</td>
                <td>
                    <strong>@item.AvailableCopies</strong> / @item.TotalCopies
                </td>
                <td>
                    @if (item.AvailableCopies > 0)
                    {
                        <span class="badge-available">Available</span>
                    }
                    else
                    {
                        <span class="badge-unavailable">All Borrowed</span>
                    }
                </td>
                <td>@Html.DisplayFor(modelItem => item.Description)</td>
                <td>@Html.DisplayFor(modelItem => item.DateAdded)</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.BookId" class="btn btn-info btn-sm">Details</a>
                    @if (User.IsInRole("Librarian"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.BookId" class="btn btn-warning btn-sm">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.BookId" class="btn btn-danger btn-sm">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>